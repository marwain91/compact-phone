<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>          <string>en</string>
    <key>CFBundleDisplayName</key>                <string>Compact Phone</string>
    <key>CFBundleExecutable</key>                 <string>${MACOSX_BUNDLE_EXECUTABLE_NAME}</string>
    <key>CFBundleIconFile</key>                   <string>compactphone.icns</string>
    <key>CFBundleIdentifier</key>                 <string>eu.havliczech.compactphone</string>
    <key>CFBundleInfoDictionaryVersion</key>      <string>6.0</string>
    <key>CFBundleName</key>                       <string>Compact Phone</string>
    <key>CFBundlePackageType</key>                <string>APPL</string>
    <key>CFBundleShortVersionString</key>         <string>${PROJECT_VERSION}</string>
    <key>CFBundleVersion</key>                    <string>${PROJECT_VERSION}</string>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Jiri Havlicek. Distributed under the GNU GPL v3 or later. Source: https://github.com/marwain91/compact-phone</string>
    <key>LSMinimumSystemVersion</key>             <string>12.0</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Compact Phone needs microphone access to make and receive SIP calls.</string>
    <key>NSHighResolutionCapable</key>            <true/>
    <key>NSPrincipalClass</key>                   <string>NSApplication</string>
    <key>LSApplicationCategoryType</key>          <string>public.app-category.business</string>
    <key>LSUIElement</key>                        <false/>
    <key>NSSupportsAutomaticGraphicsSwitching</key> <true/>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>SIP URI</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>sip</string>
                <string>sips</string>
                <string>tel</string>
                <string>callto</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
