# Copy this file to .env.local and fill in the values. .env.local is
# gitignored so your VPS hostname never lands in the public repo.
#
#   cp .env.local.example .env.local
#   $EDITOR .env.local
#
# Variables consumed by the `make remote-*` targets.

# SSH target for offloading heavy builds. Either user@host or an alias
# from your ~/.ssh/config. Required for any `make remote-*` invocation.
# Example: REMOTE_BUILD_HOST=root@vps1.example.com
REMOTE_BUILD_HOST=

# Absolute path on the VPS where the synced workspace lives. Default
# /srv/compactphone-build is fine for single-user VPSes; pick a per-user
# path if multiple devs share the box.
REMOTE_BUILD_PATH=/srv/compactphone-build
